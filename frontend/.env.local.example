# Copy this file to .env.local and adjust as needed.
# .env.local is gitignored — never commit real values.

# ===== Production (hosted backend on Render) =====
# Base URL of the FastAPI backend (Phase 1)
NEXT_PUBLIC_API_BASE_URL=https://stock-analysis-t6yt.onrender.com/api/v1
# WebSocket base (no /api/v1 prefix — see backend main.py). Use wss:// over HTTPS.
NEXT_PUBLIC_WS_URL=wss://stock-analysis-t6yt.onrender.com/ws/market
# ML service (Phase 4) base URL — no separate hosted ML URL yet; falls back to backend host.
NEXT_PUBLIC_ML_API_URL=https://stock-analysis-t6yt.onrender.com

# ===== Local development (uncomment to run against a local backend) =====
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market
# NEXT_PUBLIC_ML_API_URL=http://localhost:8100
