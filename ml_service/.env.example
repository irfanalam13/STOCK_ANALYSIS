# ---- Service ----
APP_NAME="NEPSE AI ML Service"
ENVIRONMENT=development
DEBUG=true

# ---- Auth (MUST match the core backend SECRET_KEY so its JWTs are accepted) ----
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
# Optional comma-separated API keys for service-to-service calls
ML_API_KEYS=

# ---- Redis (prediction cache + rate limiting) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
PREDICTION_CACHE_TTL=30
RATE_LIMIT_PER_MIN=120

# ---- Data source ----
# When true, load real OHLCV history from Postgres; otherwise use the built-in
# synthetic generator (lets the service train/serve with zero dependencies).
USE_DB=false
POSTGRES_USER=nepse
POSTGRES_PASSWORD=nepse_secret
POSTGRES_DB=nepse_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Models ----
MODEL_DIR=model_store
LOOKBACK=150
