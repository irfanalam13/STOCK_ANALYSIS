# ---- Application ----
APP_NAME="NEPSE Trading Backend"
# Production (hosted on Render): use "production" / DEBUG=false.
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
# Local development (uncomment for local runs):
# ENVIRONMENT=development
# DEBUG=true

# ---- CORS ----
# Comma-separated allowed origins. Use the hosted Vercel frontend in production.
CORS_ORIGINS=https://stock-analysis-orcin-phi.vercel.app
# Local development (uncomment to allow the local Next.js dev server):
# CORS_ORIGINS=http://localhost:3000
# Hosted backend URL (for reference): https://stock-analysis-t6yt.onrender.com

# ---- HTTPS hardening ----
# Enabled because the hosted backend is served over HTTPS.
HSTS_ENABLED=true
# Local development (served over HTTP) — uncomment to disable:
# HSTS_ENABLED=false

# ---- PostgreSQL ----
POSTGRES_USER=nepse
POSTGRES_PASSWORD=nepse_secret
POSTGRES_DB=nepse_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- Security ----
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ---- Market data ----
# Interval (seconds) the scheduler triggers a NEPSE fetch
MARKET_FETCH_INTERVAL=15
# Set to a real NEPSE source URL to disable the built-in simulator
NEPSE_API_URL=
# TTL (seconds) for cached quotes in Redis
CACHE_TTL_SECONDS=10
